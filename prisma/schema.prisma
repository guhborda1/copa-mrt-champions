generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Franchise {
  id     String @id @default(uuid())
  name   String
  points Int    @default(0)

  @@map("franchises")
}

model Seller {
  id     String @id @default(uuid())
  name   String
  points Int    @default(0)

  @@map("sellers")
}

model CampaignInfo {
  id       Int     @id
  prize    String  @default("Troféu Copa MRT 2026")
  end_date String?

  @@map("campaign_info")
}
